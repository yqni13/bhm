{
  "name": "bhm-ui",
  "version": "0.5.3",
  "scripts": {
    "ng": "ng",
    "start": "node ./scripts/set-env.dev.ts && ng serve --open",
    "build": "ng build",
    "build:stag": "node ./scripts/set-env.ts && ng build --configuration staging",
    "build:prod": "node ./scripts/set-env.ts && ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "serve:ssr:bhm_ui": "node dist/bhm_ui/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@11.18.0",
  "dependencies": {
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "@angular/platform-server": "^22.0.7",
    "@angular/router": "^22.0.7",
    "@angular/ssr": "^22.0.7",
    "axios": "^1.18.1",
    "esbuild": "^0.28.1",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "angular-eslint": "22.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.0.8"
  }
}
